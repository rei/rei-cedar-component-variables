{
  "name": "cdr-surface-selection",
  "notes": [
    "See the CdrFulfillmentTile docs page for more information on accessibility requirements for surface selections. For variable examples, see CdrFulfillmentTile.vars.scss source file."
  ],
  "docs": "https://cedar.rei.com/components/fulfillment-tile/",
  "examples": [
    {
      "name": "default",
      "html": "<button class=\"cdr-fulfillment-tile-default\"/>",
      "scss": [
        "@include cdr-surface-base-mixin(",
        "  $fulfillment-tile-background-colors,",
        "  $fulfillment-tile-border-colors,",
        "  $fulfillment-tile-component",
        ");",
        "@include cdr-surface-selection-base-mixin(",
        "  $fulfillment-tile-component",
        ");",
        "@include cdr-surface-selection-states-mixin(",
        "  $fulfillment-tile-background-colors,",
        "  $fulfillment-tile-border-colors,",
        "  $fulfillment-tile-component",
        ");",
        "@include cdr-fulfillment-tile-base-mixin()"
      ]
    }
  ]
}
